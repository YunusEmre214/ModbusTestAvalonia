<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ModbusTestAvalonia.MainWindow"
        Title="Modbus Master Test Tool (Avalonia)" Width="1220" Height="700">

	<Grid ColumnDefinitions="*, 280" Margin="15">

		<Grid Grid.Column="0" RowDefinitions="Auto, Auto, Auto, Auto, *, Auto" Margin="0,0,15,0">

			<StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="0,0,0,15">
				<ComboBox Name="cmbConnectionType" SelectedIndex="0" Width="190" SelectionChanged="CmbConnectionType_SelectionChanged">
					<ComboBoxItem Content="Modbus TCP/IP"/>
					<ComboBoxItem Content="Serial Port (RTU)"/>
					<ComboBoxItem Content="Modbus UDP/IP"/>
					<ComboBoxItem Content="Modbus RTU Over TCP/IP"/>
					<ComboBoxItem Content="Modbus RTU Over UDP/IP"/>
				</ComboBox>

				<TextBlock Name="lblIpAddress" Text="IP:" VerticalAlignment="Center" FontWeight="Bold"/>
				<TextBox Name="txtIpAddress" Text="127.0.0.1" Width="110" TextChanged="IpTextBox_TextChanged"/>
				<ComboBox Name="cmbComPort" Width="110" IsVisible="False"/>

				<TextBlock Name="lblPort" Text="Port:" VerticalAlignment="Center" FontWeight="Bold"/>
				<TextBox Name="txtPort" Text="502" Width="70" TextChanged="NumericTextBox_TextChanged"/>
				<ComboBox Name="cmbBaudRate" Width="90" IsVisible="False"/>

				<TextBlock Text="Intv[ms]:" VerticalAlignment="Center" FontWeight="Bold"/>
				<TextBox Name="txtPollInterval" Text="1000" Width="50" TextChanged="NumericTextBox_TextChanged"/>

				<Button Name="btnConnect" Content="Connect" Click="BtnConnect_Click" Width="100" HorizontalContentAlignment="Center"/>

			</StackPanel>

			<!-- YENİ SATIR: Serial Port (RTU) seçiliyken görünen ayarlar -->
			<StackPanel Name="pnlSerialSettings" Grid.Row="1" Orientation="Horizontal" Spacing="10" Margin="0,0,0,15"  IsVisible="False">
				<TextBlock Name="lblDataBits" Text="Data Bits:" VerticalAlignment="Center" FontWeight="Bold"/>
				<ComboBox Name="cmbDataBits" Width="120" SelectedIndex="0">
					<ComboBoxItem Content="8 Data Bits"/>
					<ComboBoxItem Content="7 Data Bits"/>
					<ComboBoxItem Content="6 Data Bits"/>
					<ComboBoxItem Content="5 Data Bits"/>
				</ComboBox>

				<TextBlock Name="lblParity" Text="Parity:" VerticalAlignment="Center" FontWeight="Bold"/>
				<ComboBox Name="cmbParity" Width="150" SelectedIndex="0">
					<ComboBoxItem Content="None Parity"/>
					<ComboBoxItem Content="Odd Parity"/>
					<ComboBoxItem Content="Even Parity"/>
					<ComboBoxItem Content="Mark Parity"/>
					<ComboBoxItem Content="Space Parity"/>
				</ComboBox>

				<TextBlock Name="lblStopBits" Text="Stop Bits:" VerticalAlignment="Center" FontWeight="Bold"/>
				<ComboBox Name="cmbStopBits" Width="200" SelectedIndex="0">
					<ComboBoxItem Content="One Stop Bits"/>
					<ComboBoxItem Content="OnePointFive Stop Bits"/>
					<ComboBoxItem Content="Two Stop Bits"/>
				</ComboBox>
			</StackPanel>

			<StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="10" Margin="0,0,0,15">
				<TextBlock Text="Slave ID:" VerticalAlignment="Center" FontWeight="Bold"/>
				<TextBox Name="txtSlaveId" Text="1" Width="40" TextChanged="NumericTextBox_TextChanged"/>

				<TextBlock Text="Start Address:" VerticalAlignment="Center" FontWeight="Bold"/>
				<TextBox Name="txtStartAddress" Text="0" Width="60" TextChanged="NumericTextBox_TextChanged"/>

				<TextBlock Text="Quantity:" VerticalAlignment="Center" FontWeight="Bold"/>
				<TextBox Name="txtQuantity" Text="10" Width="60" TextChanged="NumericTextBox_TextChanged"/>

				<ComboBox Name="cmbFunction" SelectedIndex="2" Width="180">
					<ComboBoxItem Content="01 Coil Status (0x)"/>
					<ComboBoxItem Content="02 Input Status (1x)"/>
					<ComboBoxItem Content="03 Holding Register (4x)"/>
					<ComboBoxItem Content="04 Input Registers (3x)"/>
				</ComboBox>

				<ComboBox Name="cmbDataType" SelectedIndex="1" Width="135">
					<ComboBoxItem Content="Signed"/>
					<ComboBoxItem Content="Unsigned"/>
					<ComboBoxItem Content="Hex"/>
					<ComboBoxItem Content="Binary"/>
					<ComboBoxItem Content="Float"/>
					<ComboBoxItem Content="Float inverse"/>
					<ComboBoxItem Content="Double"/>
					<ComboBoxItem Content="Double Inverse"/>
					<ComboBoxItem Content="Long"/>
					<ComboBoxItem Content="Long Inverse"/>
				</ComboBox>
			</StackPanel>

			<StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="10" Margin="0,0,0,15">
				<TextBlock Text="Write Address:" VerticalAlignment="Center" FontWeight="SemiBold"/>
				<TextBox Name="txtWriteAddress" Width="60" TextChanged="NumericTextBox_TextChanged"/>

				<TextBlock Text="Write Value:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="15,0,0,0"/>
				<TextBox Name="txtWriteValue" Width="80" TextChanged="WriteValueTextBox_TextChanged"/>

				<Button Name="btnWrite" Content="Write" Click="BtnWrite_Click" Width="80" HorizontalContentAlignment="Center"/>
			</StackPanel>

			<DataGrid Name="dataGridViewRegisters" x:CompileBindings="False" Grid.Row="4" AutoGenerateColumns="False" Margin="0,0,0,15" BorderBrush="Gray" BorderThickness="1"
          DoubleTapped="DataGridViewRegisters_DoubleTapped">
				<DataGrid.Columns>
					<DataGridTextColumn Header="Address" Binding="{Binding Address}" IsReadOnly="True" Width="150"/>
					<DataGridTextColumn Header="Value" Binding="{Binding Value}" IsReadOnly="True" Width="*"/>
				</DataGrid.Columns>
			</DataGrid>

			<Border Grid.Row="5" Background="Black" BorderThickness="1" BorderBrush="Gray" Height="120">
				<ScrollViewer>
					<ItemsControl Name="lstLogs" x:CompileBindings="False" Margin="5">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<TextBlock Text="{Binding Message}" Foreground="{Binding Color}" FontFamily="Consolas" TextWrapping="Wrap"/>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</ScrollViewer>
			</Border>
		</Grid>

		<Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Padding="10">
			<Grid RowDefinitions="Auto, Auto, Auto, *">
				<TextBlock Text="Device Management" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>

				<StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="5" Margin="0,0,0,10">
					<TextBox Name="txtNewDevName" Watermark="Device Name" Width="160"/>
					<TextBox Name="txtNewDevId" Watermark="ID" Width="60" TextChanged="NumericTextBox_TextChanged"/>
				</StackPanel>

				<StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="10" Margin="0,0,0,15">
					<Button Name="btnAddDevice" Content="Add Device" Click="BtnAddDevice_Click" Width="110" HorizontalContentAlignment="Center"/>
					<Button Name="btnDeleteDevice" Content="Delete" Click="BtnDeleteDevice_Click" Width="110" HorizontalContentAlignment="Center"/>
				</StackPanel>

				<ListBox Name="lstDevices" x:CompileBindings="False" Grid.Row="3" SelectionChanged="LstDevices_SelectionChanged" BorderThickness="1" BorderBrush="LightGray">
					<ListBox.ItemTemplate>
						<DataTemplate>
							<TextBlock Text="{Binding Name}" FontWeight="Medium" Padding="0,5"/>
						</DataTemplate>
					</ListBox.ItemTemplate>
				</ListBox>
			</Grid>
		</Border>

	</Grid>
</Window>
